# Copy to .env on the VPS and fill in real values. .env is gitignored.

# Postgres on the VPS host (reached via the host-gateway mapping in docker-compose.yml).
DATABASE_URL=postgres://rbf_user:strong-password@host.docker.internal:5432/rbf_platform

# Keep DEBUG off on the shared test box.
DEBUG=False

# Comma-separated hosts the test instance answers on (added to the built-in domains).
ALLOWED_HOSTS=test.yourdomain.com,your.vps.ip

# Generate a fresh key, e.g.:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me

# Redis for Django Channels (the compose service name is "redis").
REDIS_URL=redis://redis:6379/0

# Leave USE_S3 unset to store uploads locally in the media volume (recommended for a
# test box so uploads don't hit the prod S3 bucket). Set USE_S3=TRUE only if intended.
# USE_S3=TRUE

# Point email at a test mailbox (or swap EMAIL_BACKEND to console) so real users aren't emailed.
EMAIL_HOST=smtp.gmail.com
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_FROM=
EMAIL_PORT=587
EMAIL_USE_TLS=True
